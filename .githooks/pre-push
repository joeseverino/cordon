#!/usr/bin/env bash
# pre-push — never push red. Run the same gate CI runs before anything leaves
# the machine. CI runs `npm test` (the conformance fixture suite via
# conformance/validate.mjs); so does this. Emergency bypass: git push --no-verify
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

[[ -f package.json ]] || exit 0
echo "pre-push: npm test"
if ! npm test --silent; then
    echo "✗ Gate failed — push aborted. Fix it, or bypass: git push --no-verify" >&2
    exit 1
fi
